# Variables de entorno para Vercel
# COPIA estos valores y pégalos en Vercel → Settings → Environment Variables

# Base de datos SQLite (ruta relativa para Vercel)
DATABASE_URL=file:./db/custom.db

# Secreto para autenticación (cambia esto por algo largo y aleatorio)
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo-12345678

# URL de tu app en Vercel (cambia TU-NOMBRE por el que te dé Vercel)
NEXTAUTH_URL=https://TU-NOMBRE.vercel.app
