# ─── BASE DE DATOS (Neon PostgreSQL) ───────────────────────────────────────────
# Obtené estas URLs en: https://neon.tech → tu proyecto → Connection Details
# Seleccioná "Prisma" en el dropdown para ver el formato correcto

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ─── AUTENTICACIÓN ─────────────────────────────────────────────────────────────
# Generá un secreto largo y aleatorio (ej: abrí una terminal y corré: openssl rand -base64 32)
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# URL de tu app en Vercel (la obtenés después del primer deploy)
NEXTAUTH_URL=https://TU-PROYECTO.vercel.app
